# POIESIS 서버 환경변수 예시
# 실제 값으로 채워 .env 로 저장하거나, 배포 서비스(Render 등)의 Environment에 입력하세요.

# --- 필수 ---
SESSION_SECRET=여기에-아주-긴-무작위-문자열
NODE_ENV=production
PORT=4000
APP_ORIGIN=https://your-domain.com

# --- 카카오 로그인 (developers.kakao.com 에서 발급) ---
KAKAO_CLIENT_ID=카카오_REST_API_키
KAKAO_CLIENT_SECRET=카카오_client_secret(선택, 보안강화 시)
KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/kakao/callback

# --- 토스페이먼츠 (developers.tosspayments.com) ---
# 테스트 키는 가입 즉시 발급. 실결제는 사업자 심사 후 라이브 키로 교체.
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxx

# --- DB 파일 경로 (기본: 서버 폴더 내 poiesis.db) ---
# 배포 시 영구 디스크 경로로 지정하거나 PostgreSQL로 전환 권장
DB_PATH=/data/poiesis.db
